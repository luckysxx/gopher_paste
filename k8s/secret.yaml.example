# ==========================================
# Secret 模板文件（仅供参考）
# ==========================================
# 💡 这个文件会提交到 Git，但不包含真实密码
# 💡 团队成员可以复制这个文件为 secret.yaml，然后填入真实密码
# 💡 使用方法：cp secret.yaml.example secret.yaml
#            然后修改 secret.yaml 中的密码

apiVersion: v1
kind: Secret
metadata:
  name: gopher-secrets
  namespace: default
  labels:
    app: gopher-paste
type: Opaque

# ==========================================
# 使用 stringData（方便阅读和修改）
# ==========================================
# 💡 复制这个文件后，修改下面的值为你的真实密码
stringData:
  # Redis 密码
  redis-password: "YOUR_REDIS_PASSWORD_HERE"
  
  # PostgreSQL 配置
  postgres-user: "YOUR_POSTGRES_USER_HERE"
  postgres-password: "YOUR_POSTGRES_PASSWORD_HERE"
  
  # JWT 密钥（建议随机生成 64 位字符串）
  jwt-secret: "YOUR_JWT_SECRET_KEY_HERE"

# ==========================================
# 💡 快速生成强密码的方法
# ==========================================
# Redis 密码：
#   openssl rand -base64 32
#
# PostgreSQL 密码：
#   openssl rand -base64 32
#
# JWT 密钥：
#   openssl rand -hex 64
#
# 或者使用在线工具：
#   https://www.random.org/passwords/
